    <mxCell id="rate_limiter" value="Rate Limiter&#xa;(per user / per IP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="api_server">
      <mxGeometry x="180" y="48" width="145" height="58" as="geometry" />
    </mxCell>

    <mxCell id="sub_handler" value="Submission Handler&#xa;• Save submission (PENDING)&#xa;• Publish to Kafka" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="api_server">
      <mxGeometry x="20" y="128" width="195" height="70" as="geometry" />
    </mxCell>

    <mxCell id="sse_manager" value="SSE Manager&#xa;• in-memory client map&#xa;• Subscribe Redis Pub/Sub&#xa;• Fan-out on leaderboard update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="api_server">
      <mxGeometry x="355" y="48" width="190" height="155" as="geometry" />
    </mxCell>

    <mxCell id="kafka" value="KAFKA&#xa;topic: action-submissions&#xa;partition key: user_id" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="880" y="270" width="185" height="120" as="geometry" />
    </mxCell>

    <mxCell id="worker" value="VALIDATION WORKER (consumer group)" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="210" y="600" width="740" height="205" as="geometry" />
    </mxCell>

    <mxCell id="w1" value="① Acquire Redlock&#xa;lock:submit:{uid}:{aid}&#xa;TTL: 30s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="worker">
      <mxGeometry x="10" y="45" width="160" height="65" as="geometry" />
    </mxCell>

    <mxCell id="w2" value="② Idempotency check&#xa;UNIQUE(user_id, action_id)&#xa;skip if already VALID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="worker">
      <mxGeometry x="185" y="45" width="165" height="65" as="geometry" />
    </mxCell>

    <mxCell id="w3" value="③ Verify proof&#xa;④ Fetch score_value&#xa;   from actions table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="worker">
      <mxGeometry x="365" y="45" width="160" height="65" as="geometry" />
    </mxCell>

    <mxCell id="w4" value="⑤ Atomic UPDATE score&#xa;   score = score + delta&#xa;⑥ Optimistic lock (version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="worker">
      <mxGeometry x="540" y="45" width="185" height="65" as="geometry" />
    </mxCell>

    <mxCell id="w5" value="⑦ ZADD leaderboard     ⑧ Compare top10     ⑨ Publish Pub/Sub if changed     ⑩ Mark VALID + release Redlock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="worker">
      <mxGeometry x="185" y="130" width="380" height="55" as="geometry" />
    </mxCell>

    <mxCell id="postgres" value="PostgreSQL&#xa;users / actions / submissions" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="628" width="175" height="120" as="geometry" />
