      <mxGeometry x="1140" y="205" width="250" height="365" as="geometry" />
    </mxCell>

    <mxCell id="redis_sorted" value="Sorted Set&#xa;ZADD leaderboard &lt;score&gt; &lt;uid&gt;&#xa;ZREVRANGE 0 9 → top 10&#xa;O(log N) insert / O(K) query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="redis">
      <mxGeometry x="15" y="35" width="220" height="80" as="geometry" />
    </mxCell>

    <mxCell id="redis_pubsub" value="Pub/Sub&#xa;channel: leaderboard:top10&#xa;Fan-out to all API instances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="redis">
      <mxGeometry x="15" y="130" width="220" height="75" as="geometry" />
    </mxCell>

    <mxCell id="redis_lock" value="Redlock&#xa;lock:submit:{user_id}:{action_id}&#xa;TTL: 30s — prevents duplicate&#xa;concurrent processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="redis">
      <mxGeometry x="15" y="220" width="220" height="80" as="geometry" />
    </mxCell>

    <mxCell id="dlq" value="Dead Letter Queue (DLQ)&#xa;Unprocessable messages&#xa;→ Alert + manual review" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1150" y="660" width="210" height="110" as="geometry" />
    </mxCell>

    <mxCell id="legend" value="Race Condition: 3 Layers&#xa;Layer 1: Redlock + UNIQUE(user_id, action_id)&#xa;Layer 2: Kafka partition by user_id → sequential per user&#xa;Layer 3: Atomic SQL + Optimistic Lock (version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="40" y="870" width="380" height="85" as="geometry" />
    </mxCell>

    <mxCell id="legend2" value="SSE Fan-out (multi-instance)&#xa;Worker → Redis Pub/Sub → All API instances&#xa;Each instance fans out to local SSE clients&#xa;Throttle: broadcast only when top 10 changes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="440" y="870" width="380" height="85" as="geometry" />
    </mxCell>

