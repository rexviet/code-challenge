# Application
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Database (docker-compose overrides DB_HOST to "postgres")
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=crud_db

# Redis (docker-compose overrides REDIS_HOST to "redis")
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=300

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Mock Auth (set to false to skip auth in development)
MOCK_AUTH_ENABLED=true
